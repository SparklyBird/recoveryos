#!/bin/sh
. /usr/local/bin/recoveryos-mountlib
G='\033[0;32m'; GB='\033[1;32m'; RD='\033[1;31m'; YL='\033[1;33m'; R='\033[0m'
MNT=/mnt/win; mkdir -p "$MNT"
STATE=/run/recoveryos
VERBOSE=0; [ -f "$STATE/verbose" ] && VERBOSE=$(cat "$STATE/verbose" 2>/dev/null)
HELPER=/usr/local/bin/recoveryos-wifidecrypt
TAB=$(printf '\t')
pause() { printf "\n  ${GB}Press ENTER to continue...${R}"; read x; }

fallback_list() {
        P=$(find "$MNT" -ipath '*/ProgramData/Microsoft/Wlansvc/Profiles/Interfaces/*' -name '*.xml' 2>/dev/null)
        [ -z "$P" ] && { printf "  ${YL}No saved WiFi profiles found.${R}\n"; return; }
        C=$(echo "$P" | wc -l)
        printf "  ${GB}Found $C saved WiFi profile(s):${R}\n\n"
        for xml in $P; do
                s=$(sed -n 's|.*<name>\([^<]*\)</name>.*|\1|p' "$xml" | head -1)
                k=$(sed -n 's|.*<keyMaterial>\([^<]*\)</keyMaterial>.*|\1|p' "$xml" | head -1)
                a=$(sed -n 's|.*<authentication>\([^<]*\)</authentication>.*|\1|p' "$xml" | head -1)
                pr=$(sed -n 's|.*<protected>\([^<]*\)</protected>.*|\1|p' "$xml" | head -1)
                printf "  ${GB}SSID:${R} ${G}$s${R}\n"
                [ -n "$a" ] && printf "    ${G}Auth: $a${R}\n"
                if [ -z "$k" ]; then printf "    ${G}(open network or no key stored)${R}\n"
                elif [ "$pr" = "false" ]; then printf "    ${GB}Key: $k${R}  ${G}(cleartext)${R}\n"
                else printf "    ${YL}Key: [encrypted - decryptor unavailable]${R}\n"; fi
                printf "\n"
        done
}

clear
printf "\n  ${GB}=== Recover WiFi Passwords ===${R}\n\n"

WIN_FOUND=0; WIN_PART=""
[ -f "$STATE/win.conf" ] && . "$STATE/win.conf" 2>/dev/null
if [ "$WIN_FOUND" != "1" ] || [ -z "$WIN_PART" ]; then
        printf "  ${RD}No Windows installation found.${R}\n"; pause; exit 0
fi

[ "$VERBOSE" = "1" ] && printf "  ${G}Mounting $WIN_PART read-only...${R}\n"
if ! ros_mount_ro "$WIN_PART" "$MNT"; then
        printf "  ${RD}Could not mount $WIN_PART.${R}\n"; ros_verr "ntfs-3g said:"; pause; exit 0
fi
i=0; while [ ! -d "$MNT/Windows/System32/Microsoft/Protect/S-1-5-18" ] && [ "$i" -lt 10 ]; do sleep 1; i=$((i+1)); done
printf "  ${GB}Found Windows on: $WIN_PART${R}\n\n"

if ! command -v python3 >/dev/null 2>&1 || [ ! -f "$HELPER" ]; then
        fallback_list
        umount "$MNT" 2>/dev/null; pause; exit 0
fi

[ "$VERBOSE" = "1" ] && printf "  ${G}Decrypting via SYSTEM DPAPI master key...${R}\n\n"
ERRF=$(mktemp 2>/dev/null || echo /tmp/ros-wifi-err)
OUT=$(python3 "$HELPER" "$MNT" 2>"$ERRF")
RC=$?

if [ "$RC" != "0" ]; then
        printf "  ${YL}Decryptor error - listing SSIDs only.${R}\n"
        [ "$VERBOSE" = "1" ] && [ -s "$ERRF" ] && sed 's/^/    /' "$ERRF"
        printf "\n"
        fallback_list
        rm -f "$ERRF"; umount "$MNT" 2>/dev/null; pause; exit 0
fi
[ "$VERBOSE" = "1" ] && [ -s "$ERRF" ] && { printf "  ${YL}Decryptor notes:${R}\n"; sed 's/^/    /' "$ERRF"; printf "\n"; }
rm -f "$ERRF"

if [ -z "$OUT" ]; then
        printf "  ${YL}No saved WiFi profiles found.${R}\n"
        umount "$MNT" 2>/dev/null; pause; exit 0
fi

COUNT=$(printf '%s\n' "$OUT" | grep -c .)
printf "  ${GB}Found $COUNT saved WiFi profile(s):${R}\n\n"
printf '%s\n' "$OUT" | while IFS="$TAB" read -r SSID AUTH STATUS KEY; do
        printf "  ${GB}SSID:${R} ${G}$SSID${R}\n"
        [ -n "$AUTH" ] && printf "    ${G}Auth: $AUTH${R}\n"
        case "$STATUS" in
                decrypted) printf "    ${GB}Key: $KEY${R}  ${G}(decrypted)${R}\n" ;;
                cleartext) printf "    ${GB}Key: $KEY${R}  ${G}(cleartext)${R}\n" ;;
                open)      printf "    ${G}(open network or no key stored)${R}\n" ;;
                *)         printf "    ${YL}Key: [encrypted - master key unavailable]${R}\n" ;;
        esac
        printf "\n"
done
printf "  ${G}--------------------------------------------------${R}\n"
printf "  ${G}Keys decrypted offline via the SYSTEM DPAPI master${R}\n"
printf "  ${G}key (SYSTEM + SECURITY hives). BitLocker stays locked.${R}\n"
umount "$MNT" 2>/dev/null; pause
