#!/bin/sh
. /usr/local/bin/recoveryos-mountlib
G='\033[0;32m'; GB='\033[1;32m'; RD='\033[1;31m'; YL='\033[1;33m'; R='\033[0m'
MNT=/mnt/win; mkdir -p "$MNT"
STATE=/run/recoveryos
VERBOSE=0; [ -f "$STATE/verbose" ] && VERBOSE=$(cat "$STATE/verbose" 2>/dev/null)
pause() { printf "\n  ${GB}Press ENTER to continue...${R}"; read x; }
clear
printf "\n  ${GB}=== Reset Windows Password ===${R}\n\n"

WIN_FOUND=0; WIN_PART=""; WIN_SAM=""; WIN_LOCKED=""
[ -f "$STATE/win.conf" ] && . "$STATE/win.conf" 2>/dev/null

if [ "$WIN_FOUND" != "1" ] || [ -z "$WIN_PART" ]; then
        printf "  ${RD}No accessible Windows installation found.${R}\n\n"
        if [ -n "$WIN_LOCKED" ]; then
                printf "  ${YL}Could not open:$WIN_LOCKED${R}\n\n"
                printf "  ${G}Likely BitLocker or fast-startup/hibernation.${R}\n"
                printf "  ${G}Fully shut down Windows (Shift+Shutdown), or get${R}\n"
                printf "  ${G}the BitLocker key from:${R}\n"
                printf "  ${GB}https://account.microsoft.com/devices/recoverykey${R}\n"
        else
                printf "  ${G}No Windows partitions detected at boot.${R}\n"
        fi
        pause; exit 0
fi

printf "  ${GB}Found Windows on: $WIN_PART${R}\n"
[ "$VERBOSE" = "1" ] && printf "  ${G}(from boot detection, SAM: $WIN_SAM)${R}\n"
printf "\n  ${G}Mounting read-write...${R}\n"

if ! ros_mount_rw "$WIN_PART" "$MNT"; then
        printf "  ${RD}Could not mount $WIN_PART read-write.${R}\n"
        ros_verr "ntfs-3g said:"
        printf "  ${YL}May be BitLocker-encrypted or disk failing.${R}\n"
        pause; exit 0
fi

if ros_has_hiberfile "$MNT"; then
        printf "\n  ${YL}Hibernation/fast-startup file detected.${R}\n"
        printf "  ${YL}Windows did not fully shut down. Writing now will${R}\n"
        printf "  ${YL}DISCARD the saved session (unsaved work is lost).${R}\n\n"
        printf "  ${G}Best: cancel, boot Windows, Shift+Shutdown, retry.${R}\n"
        printf "  ${GB}Clear it and continue anyway? [yes/N]:${R} "; read HCONF
        case "$HCONF" in
                yes|YES|Yes)
                        if ! ros_mount_rw_clear "$WIN_PART" "$MNT"; then
                                printf "  ${RD}Could not clear hiberfile / remount.${R}\n"; ros_verr "ntfs-3g said:"; pause; exit 0
                        fi
                        ;;
                *) printf "\n  ${G}Cancelled. No changes made.${R}\n"; umount "$MNT" 2>/dev/null; pause; exit 0 ;;
        esac
fi

SAMPATH="$MNT/$WIN_SAM"
if [ ! -f "$SAMPATH" ]; then
        SAMPATH=$(find "$MNT" -maxdepth 4 -ipath '*/system32/config/sam' 2>/dev/null | head -1)
fi
if [ -z "$SAMPATH" ] || [ ! -f "$SAMPATH" ]; then
        printf "  ${RD}SAM hive not found on $WIN_PART.${R}\n"
        umount "$MNT" 2>/dev/null; pause; exit 0
fi
printf "  ${G}SAM hive: $SAMPATH${R}\n\n"
printf "  ${G}Reading local accounts...${R}\n\n"

chntpw -l "$SAMPATH" 2>/dev/null | awk -F'|' '/^\| [0-9a-f]/ {
        gsub(/^ +| +$/,"",$3)
        gsub(/^ +| +$/,"",$4)
        if ($3 != "") printf "%s|%s\n", $3, $4
}' > /tmp/users.txt

UCOUNT=$(wc -l < /tmp/users.txt 2>/dev/null)
if [ "${UCOUNT:-0}" -eq 0 ]; then
        printf "  ${RD}Could not read accounts from SAM hive.${R}\n"
        printf "  ${G}The hive may be corrupted or from an unsupported${R}\n"
        printf "  ${G}Windows version (chntpw supports up to Win10/11).${R}\n"
        umount "$MNT" 2>/dev/null; pause; exit 0
fi

printf "  ${GB}Found $UCOUNT local account(s):${R}\n\n"
i=1
while IFS='|' read -r USER ADMIN; do
        if [ "$ADMIN" = "ADMIN" ]; then
                printf "  ${G}%2d)${R} ${GB}%s${R}  ${YL}[Admin]${R}\n" "$i" "$USER"
        else
                printf "  ${G}%2d)${R} ${G}%s${R}\n" "$i" "$USER"
        fi
        i=$((i+1))
done < /tmp/users.txt

printf "\n  ${YL}Note: Microsoft accounts authenticate online and${R}\n"
printf "  ${YL}cannot be reset here. Only local accounts work.${R}\n\n"
printf "  ${GB}Pick number to reset (or Q to cancel):${R} "; read NUM
[ "$NUM" = "q" ] || [ "$NUM" = "Q" ] && { umount "$MNT" 2>/dev/null; exit 0; }
USERNAME=$(sed -n "${NUM}p" /tmp/users.txt | cut -d'|' -f1)
[ -z "$USERNAME" ] && { printf "  ${RD}Invalid choice.${R}\n"; umount "$MNT" 2>/dev/null; pause; exit 0; }

printf "\n  ${YL}About to modify SAM hive for user: ${GB}$USERNAME${R}\n"
printf "  ${YL}This edits the Windows registry. Type 'yes' to${R}\n"
printf "  ${YL}continue, anything else cancels:${R} "; read CONFIRM
case "$CONFIRM" in
        yes|YES|Yes) ;;
        *) printf "\n  ${G}Cancelled. No changes made.${R}\n"; umount "$MNT" 2>/dev/null; pause; exit 0 ;;
esac

clear
printf "\n  ${GB}chntpw will now open. In its menu:${R}\n"
printf "  ${G}- Choose 1 to clear (blank) the password${R}\n"
printf "  ${G}- Then q to quit, then y to write changes${R}\n\n"
pause
printf "\n\n"
chntpw -u "$USERNAME" "$SAMPATH"
printf "\n\n"
printf "  ${GB}Syncing...${R}\n"; sync; umount "$MNT" 2>/dev/null
printf "  ${GB}Done. Reboot, remove USB, boot Windows.${R}\n"; pause
