#!/bin/sh
. /usr/local/bin/recoveryos-mountlib
G='\033[0;32m'; GB='\033[1;32m'; RD='\033[1;31m'; YL='\033[1;33m'; R='\033[0m'
SRC=/mnt/recsrc; DST=/mnt/recdst; mkdir -p "$SRC" "$DST"
STATE=/run/recoveryos
VERBOSE=0; [ -f "$STATE/verbose" ] && VERBOSE=$(cat "$STATE/verbose" 2>/dev/null)
pause() { printf "\n  ${GB}Press ENTER to continue...${R}"; read x; }
cleanup() { sync; umount "$SRC" 2>/dev/null; umount "$DST" 2>/dev/null; }

show_parts() {
	lsblk -p -n -l -o NAME,SIZE,FSTYPE,LABEL,TYPE 2>/dev/null | awk '$NF=="part"' > /tmp/.recparts
	i=0
	while IFS= read -r line; do
		i=$((i+1)); printf "  ${G}%2d) %s${R}\n" "$i" "$line"
	done < /tmp/.recparts
}
get_part() { sed -n "${1}p" /tmp/.recparts 2>/dev/null | awk '{print $1}'; }

pick_dest_mount() {
	printf "\n  ${GB}Pick DESTINATION drive (copy TO):${R}\n\n"
	show_parts
	printf "\n  ${GB}Destination number (Q to cancel):${R} "; read DN
	case "$DN" in q|Q|"") return 1 ;; esac
	DSTDEV=$(get_part "$DN")
	[ -z "$DSTDEV" ] && { printf "  ${RD}Invalid choice.${R}\n"; return 1; }
	[ "$DSTDEV" = "$SRCDEV" ] && { printf "  ${RD}Destination cannot be the source.${R}\n"; return 1; }
	if ! ros_mount_rw "$DSTDEV" "$DST"; then printf "  ${RD}Could not mount $DSTDEV read-write.${R}\n"; ros_verr "$DSTDEV"; return 1; fi
	return 0
}

clear
printf "\n  ${GB}=== Smart File Recovery ===${R}\n\n"
printf "  ${G}Mounts the disk if it can:${R}\n"
printf "  ${G} - Mounts OK   -> pick personal files or everything.${R}\n"
printf "  ${G} - Won't mount -> carve readable files by type (photorec).${R}\n\n"
printf "  ${GB}Available partitions:${R}\n\n"
show_parts
printf "\n  ${GB}Pick SOURCE number (recover FROM):${R} "; read SN
SRCDEV=$(get_part "$SN")
[ -z "$SRCDEV" ] && { printf "  ${RD}Invalid choice.${R}\n"; pause; exit 0; }

printf "\n  ${G}Trying to mount $SRCDEV read-only...${R}\n"
if ros_mount_ro "$SRCDEV" "$SRC"; then
	TS=$(date +%Y%m%d-%H%M%S)
	clear
	printf "\n  ${GB}=== Smart File Recovery (disk mounted) ===${R}\n\n"
	printf "  ${GB}What to recover:${R}\n\n"
	printf "    ${GB}[1]${R} ${G}Personal - core folders only${R}\n"
	printf "        ${G}Desktop, Documents, Downloads, Pictures, Videos, Music${R}\n"
	printf "    ${GB}[2]${R} ${G}Personal - all of Users/ except AppData${R}\n"
	printf "    ${GB}[3]${R} ${G}Everything (full copy, skips pagefile/hiberfile)${R}\n\n"
	printf "  ${GB}Pick (1-3, Q to cancel):${R} "; read WHAT
	case "$WHAT" in q|Q|"") cleanup; exit 0 ;; esac
	if ! pick_dest_mount; then cleanup; pause; exit 0; fi
	OUT="$DST/recover-$TS"; mkdir -p "$OUT"
	printf "\n  ${YL}Copying to $DSTDEV : recover-$TS${R}\n  ${G}This may take a while...${R}\n\n"
	case "$WHAT" in
	1)
		if [ ! -d "$SRC/Users" ]; then printf "  ${RD}No Users/ folder here.${R}\n"; cleanup; pause; exit 0; fi
		for u in "$SRC"/Users/*/; do
			[ -d "$u" ] || continue
			un=$(basename "$u")
			case "$un" in "All Users"|"Default"|"Default User"|"defaultuser0") continue ;; esac
			for f in Desktop Documents Downloads Pictures Videos Music; do
				if [ -d "$u/$f" ]; then
					mkdir -p "$OUT/$un"
					[ "$VERBOSE" = "1" ] && printf "  ${G}-> $un/$f${R}\n"
					rsync -a --info=progress2 "$u/$f" "$OUT/$un/" 2>/dev/null
				fi
			done
		done
		;;
	2)
		if [ ! -d "$SRC/Users" ]; then printf "  ${RD}No Users/ folder here.${R}\n"; cleanup; pause; exit 0; fi
		rsync -a --info=progress2 \
			--exclude='AppData' \
			--exclude='/Default' --exclude='/Default User' --exclude='/All Users' --exclude='/defaultuser0' \
			"$SRC/Users/" "$OUT/Users/" 2>/dev/null
		;;
	3)
		rsync -a --info=progress2 \
			--exclude='pagefile.sys' --exclude='hiberfil.sys' --exclude='swapfile.sys' \
			"$SRC/" "$OUT/" 2>/dev/null
		;;
	*) printf "  ${RD}Invalid choice.${R}\n"; cleanup; pause; exit 0 ;;
	esac
	printf "\n  ${GB}Done. Recovered to:${R}\n  ${G}$DSTDEV : recover-$TS${R}\n"
	cleanup; pause
else
	clear
	printf "\n  ${GB}=== Smart File Recovery (disk will not mount) ===${R}\n\n"
	printf "  ${YL}$SRCDEV could not be mounted - filesystem damaged or${R}\n"
	printf "  ${YL}disk failing. Switching to raw carve with photorec.${R}\n\n"
	ros_verr "$SRCDEV"
	printf "  ${G}Carve reads sectors directly, rebuilds files by type.${R}\n"
	printf "  ${G}No original folder names or paths (that info is gone).${R}\n"
	printf "  ${G}In photorec: [File Opt] limits to photos/docs/video,${R}\n"
	printf "  ${G}then pick the partition and [Search].${R}\n\n"
	if ! pick_dest_mount; then pause; exit 0; fi
	TS=$(date +%Y%m%d-%H%M%S)
	OUT="$DST/carve-$TS"; mkdir -p "$OUT"
	printf "\n  ${GB}Output: $DSTDEV : carve-$TS  (destination preset)${R}\n"
	pause
	trap - INT TSTP QUIT
	photorec /d "$OUT/recovered" "$SRCDEV"
	trap '' INT TSTP QUIT
	sync; clear
	printf "\n  ${GB}photorec finished.${R}\n"
	printf "  ${G}Recovered files (if any) under:${R}\n  ${G}$DSTDEV : carve-$TS${R}\n"
	cleanup; pause
fi
