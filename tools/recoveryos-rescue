#!/bin/sh
. /usr/local/bin/recoveryos-mountlib
G='\033[0;32m'; GB='\033[1;32m'; RD='\033[1;31m'; YL='\033[1;33m'; R='\033[0m'
SRC=/mnt/src; DST=/mnt/dst; mkdir -p "$SRC" "$DST"
STATE=/run/recoveryos
VERBOSE=0; [ -f "$STATE/verbose" ] && VERBOSE=$(cat "$STATE/verbose" 2>/dev/null)
pause() { printf "\n  ${GB}Press ENTER to continue...${R}"; read x; }
cleanup() { sync; umount "$SRC" 2>/dev/null; umount "$DST" 2>/dev/null; rm -f /tmp/.smbcreds /tmp/smberr 2>/dev/null; }

show_parts() {
	EXCLUDE="$1"; i=1
	lsblk -p -n -l -o NAME,SIZE,FSTYPE,LABEL,TYPE 2>/dev/null | awk '$NF=="part"' | while read line; do
		DEV=$(echo "$line" | awk '{print $1}')
		if [ "$DEV" = "$EXCLUDE" ]; then
			printf "  ${YL}%2d) %s   [SOURCE - excluded]${R}\n" "$i" "$line"
		else
			printf "  ${G}%2d) %s${R}\n" "$i" "$line"
		fi
		i=$((i+1))
	done
}
get_part_by_num() {
	NUM="$1"
	lsblk -p -n -l -o NAME,SIZE,FSTYPE,LABEL,TYPE 2>/dev/null | awk '$NF=="part"' | sed -n "${NUM}p" | awk '{print $1}'
}
have_network() { ip -4 addr show 2>/dev/null | grep -q 'inet '; }
pick_subdir() {
	printf "\n  ${GB}Top-level folders on source:${R}\n${G}"
	ls -1 "$SRC" 2>/dev/null | head -20 | sed 's/^/    /'
	printf "${R}\n  ${GB}Folder to copy (blank = everything):${R} "; read SUBDIR
	if [ -n "$SUBDIR" ] && [ -d "$SRC/$SUBDIR" ]; then COPYFROM="$SRC/$SUBDIR"; else COPYFROM="$SRC"; fi
}

clear
printf "\n  ${GB}=== Rescue User Files ===${R}\n\n"

COUNT=$(lsblk -p -n -l -o NAME,TYPE 2>/dev/null | awk '$2=="part"' | wc -l)
if [ "$COUNT" -lt 1 ]; then printf "  ${RD}No partitions found.${R}\n"; pause; exit 0; fi
printf "  ${GB}Available partitions:${R}\n\n"
show_parts ""
printf "\n  ${GB}Pick SOURCE number (copy FROM):${R} "; read SNUM
SRCDEV=$(get_part_by_num "$SNUM")
[ -z "$SRCDEV" ] && { printf "  ${RD}Invalid choice.${R}\n"; pause; exit 0; }
if ! ros_mount_ro "$SRCDEV" "$SRC"; then printf "  ${RD}Could not mount $SRCDEV.${R}\n"; ros_verr "$SRCDEV"; pause; exit 0; fi
clear
printf "\n  ${GB}Source mounted: $SRCDEV${R}\n\n"

printf "  ${GB}Destination type:${R}\n\n"
printf "    ${GB}[1]${R} ${G}Local drive / partition${R}\n"
printf "    ${GB}[2]${R} ${G}SMB share (Windows/NAS shared folder)${R}\n"
printf "    ${GB}[3]${R} ${G}SSH / SFTP (rsync over ssh)${R}\n\n"
printf "  ${GB}Pick destination type (1-3, Q to cancel):${R} "; read DTYPE
case "$DTYPE" in q|Q|"") cleanup; exit 0 ;; esac

TS=$(date +%Y%m%d-%H%M%S)

case "$DTYPE" in
1)
	printf "\n  ${GB}Pick DESTINATION number (copy TO):${R}\n"
	printf "  ${G}(same numbering as before, skip source)${R}\n\n"
	show_parts "$SRCDEV"
	printf "\n  ${GB}Destination number:${R} "; read DNUM
	DSTDEV=$(get_part_by_num "$DNUM")
	if [ -z "$DSTDEV" ] || [ "$DSTDEV" = "$SRCDEV" ]; then printf "  ${RD}Invalid choice.${R}\n"; cleanup; pause; exit 0; fi
	printf "\n  ${YL}Will write to: ${GB}$DSTDEV${R}\n"
	printf "  ${YL}Files saved to a new timestamped folder.${R}\n"
	printf "  ${YL}Continue? [y/N]:${R} "; read CONFIRM
	case "$CONFIRM" in y|Y|yes|YES) ;; *) printf "\n  ${G}Cancelled.${R}\n"; cleanup; pause; exit 0 ;; esac
	if ! ros_mount_rw "$DSTDEV" "$DST"; then printf "  ${RD}Could not mount $DSTDEV.${R}\n"; ros_verr "$DSTDEV"; cleanup; pause; exit 0; fi
	OUT="$DST/rescue-$TS"; mkdir -p "$OUT"
	pick_subdir
	printf "\n  ${YL}Copying $COPYFROM -> $OUT${R}\n  ${G}This may take a while...${R}\n\n"
	rsync -a --info=progress2 "$COPYFROM/" "$OUT/" 2>/dev/null
	printf "\n  ${GB}Done. Files copied to:${R}\n  ${G}$DSTDEV : rescue-$TS${R}\n"
	cleanup; pause
	;;
2)
	if ! have_network; then
		printf "\n  ${RD}No network address detected.${R}\n"
		printf "  ${G}Plug in ethernet, or check [8] Network Diagnostics.${R}\n"
		cleanup; pause; exit 0
	fi
	modprobe cifs 2>/dev/null
	printf "\n  ${GB}SMB destination${R}\n\n"
	printf "  ${G}Server IP or name:${R} "; read SMBHOST
	printf "  ${G}Share name:${R} "; read SMBSHARE
	printf "  ${G}Username (blank = guest):${R} "; read SMBUSER
	if [ -n "$SMBUSER" ]; then
		printf "  ${G}Password:${R} "; stty -echo 2>/dev/null; read SMBPASS; stty echo 2>/dev/null; printf "\n"
		printf "username=%s\npassword=%s\n" "$SMBUSER" "$SMBPASS" > /tmp/.smbcreds
		chmod 600 /tmp/.smbcreds
		MOPT="credentials=/tmp/.smbcreds"
	else
		MOPT="guest"
	fi
	[ "$VERBOSE" = "1" ] && printf "\n  ${G}Mounting //$SMBHOST/$SMBSHARE ...${R}\n"
	if ! mount -t cifs "//$SMBHOST/$SMBSHARE" "$DST" -o "$MOPT" 2>/tmp/smberr; then
		printf "\n  ${RD}Could not mount SMB share.${R}\n"
		[ "$VERBOSE" = "1" ] && sed 's/^/    /' /tmp/smberr 2>/dev/null
		printf "  ${G}Check server, share name, credentials.${R}\n"
		cleanup; pause; exit 0
	fi
	OUT="$DST/rescue-$TS"; mkdir -p "$OUT"
	pick_subdir
	printf "\n  ${YL}Copying $COPYFROM -> //$SMBHOST/$SMBSHARE/rescue-$TS${R}\n  ${G}This may take a while...${R}\n\n"
	rsync -a --info=progress2 "$COPYFROM/" "$OUT/" 2>/dev/null
	printf "\n  ${GB}Done. Files copied to:${R}\n  ${G}//$SMBHOST/$SMBSHARE/rescue-$TS${R}\n"
	cleanup; pause
	;;
3)
	if ! have_network; then
		printf "\n  ${RD}No network address detected.${R}\n"
		printf "  ${G}Plug in ethernet, or check [8] Network Diagnostics.${R}\n"
		cleanup; pause; exit 0
	fi
	printf "\n  ${GB}SSH/SFTP destination${R}\n\n"
	printf "  ${G}user@host (e.g. bob@192.168.1.50):${R} "; read SSHTGT
	printf "  ${G}Remote path (e.g. /home/bob/rescue):${R} "; read SSHPATH
	if [ -z "$SSHTGT" ] || [ -z "$SSHPATH" ]; then printf "  ${RD}Need both target and path.${R}\n"; cleanup; pause; exit 0; fi
	pick_subdir
	REMOTE="$SSHPATH/rescue-$TS"
	printf "\n  ${YL}Copying $COPYFROM -> $SSHTGT:$REMOTE${R}\n"
	printf "  ${G}Enter SSH password when prompted.${R}\n  ${G}This may take a while...${R}\n\n"
	rsync -a --mkpath --info=progress2 -e "ssh -o StrictHostKeyChecking=accept-new" "$COPYFROM/" "$SSHTGT:$REMOTE/"
	RC=$?
	if [ "$RC" -ne 0 ]; then
		printf "\n  ${RD}rsync over ssh failed (code $RC).${R}\n"
		printf "  ${G}Check target, path, password, server sshd.${R}\n"
		cleanup; pause; exit 0
	fi
	printf "\n  ${GB}Done. Files copied to:${R}\n  ${G}$SSHTGT:$REMOTE${R}\n"
	cleanup; pause
	;;
*)
	printf "  ${RD}Invalid choice.${R}\n"; cleanup; pause; exit 0
	;;
esac
