#!/bin/sh
. /usr/local/bin/recoveryos-jsonlib
G='\033[0;32m'; GB='\033[1;32m'; RD='\033[1;31m'; YL='\033[1;33m'; R='\033[0m'
DST=/mnt/export; mkdir -p "$DST"
STATE=/run/recoveryos
VERBOSE=0; [ -f "$STATE/verbose" ] && VERBOSE=$(cat "$STATE/verbose" 2>/dev/null)
pause() { printf "\n  ${GB}Press ENTER to continue...${R}"; read x; }
clear
printf "\n  ${GB}=== Export JSON Report ===${R}\n\n"
printf "  ${G}Collects all diagnostics into one JSON file.${R}\n\n"
printf "  ${GB}Pick a drive to save to:${R}\n\n"
i=0
lsblk -p -n -P -o NAME,SIZE,FSTYPE,TYPE,LABEL 2>/dev/null > /tmp/.exparts
while IFS= read -r line; do
	eval "$line" 2>/dev/null
	[ "$TYPE" = "part" ] || continue
	[ -z "$FSTYPE" ] && continue
	i=$((i+1)); eval "DEV_$i=\$NAME"
	printf "    ${GB}[%s]${R} ${G}%-12s %-7s %-6s %s${R}\n" "$i" "$NAME" "$SIZE" "$FSTYPE" "$LABEL"
done < /tmp/.exparts
COUNT=$i; rm -f /tmp/.exparts
[ "$COUNT" = "0" ] && { printf "\n  ${RD}No writable partitions found.${R}\n"; pause; exit 0; }
printf "\n  ${GB}Drive number (1-$COUNT, Q to cancel):${R} "; read CH
case "$CH" in q|Q|"") exit 0 ;; esac
eval "TARGET=\$DEV_$CH"
[ -z "$TARGET" ] && { printf "  ${RD}Invalid choice.${R}\n"; pause; exit 0; }
if ! ros_mount_rw "$TARGET" "$DST"; then
	printf "  ${RD}Could not mount $TARGET read-write.${R}\n"; ros_verr "$TARGET"; pause; exit 0
fi
TS=$(date +%Y%m%d-%H%M%S)
FILE="$DST/recoveryos-report-$TS.json"
printf "\n  ${G}Collecting (disks/SMART may take a moment)...${R}\n"
{
	printf '{\n'
	printf '  "tool": "RecoveryOS",\n'
	printf '  "version": "3.23",\n'
	printf '  "timestamp": "%s",\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
	printf '  "windows": '; json_windows; printf ',\n'
	printf '  "system": '; json_system; printf ',\n'
	printf '  "disks": '; json_disks; printf ',\n'
	printf '  "sensors": '; json_sensors; printf ',\n'
	printf '  "network": '; json_network; printf ',\n'
	printf '  "wifi": '; json_wifi; printf ',\n'
	printf '  "crashlogs": '; json_crashlogs; printf '\n'
	printf '}\n'
} > "$FILE"
sync
SZ=$(ls -lh "$FILE" 2>/dev/null | awk '{print $5}')
printf "\n  ${GB}Saved:${R}\n  ${G}$TARGET : recoveryos-report-$TS.json  ($SZ)${R}\n"
umount "$DST" 2>/dev/null
pause
